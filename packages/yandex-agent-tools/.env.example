# Public-safe placeholders only. Copy to .env in private deployments and fill locally.
YAT_API_TOKEN=replace-with-local-token
YAT_DEFAULT_ACCOUNT=personal

YAT_WORK_MAIL_ADDRESS=work@example.com
YAT_WORK_MAIL_APP_PASSWORD=replace-with-mail-app-password
YAT_WORK_MAIL_DISPLAY_NAME=Work Agent
YAT_WORK_MAIL_SIGNATURE_TEXT=Regards,\nWork Agent
YAT_WORK_CALENDAR_USERNAME=work@example.com
YAT_WORK_CALENDAR_APP_PASSWORD=replace-with-calendar-app-password
YAT_WORK_CALENDAR_NAME=Work Calendar
YAT_WORK_CALENDAR_WRITES_REQUIRE_EXPLICIT_CONFIRM=true

YAT_PERSONAL_MAIL_ADDRESS=personal@example.com
YAT_PERSONAL_MAIL_APP_PASSWORD=replace-with-mail-app-password
YAT_PERSONAL_MAIL_DISPLAY_NAME=Personal Agent
YAT_PERSONAL_MAIL_SIGNATURE_TEXT=Regards,\nPersonal Agent
YAT_PERSONAL_CALENDAR_USERNAME=personal@example.com
YAT_PERSONAL_CALENDAR_APP_PASSWORD=replace-with-calendar-app-password
YAT_PERSONAL_CALENDAR_NAME=Personal Calendar
YAT_PERSONAL_CALENDAR_WRITES_REQUIRE_EXPLICIT_CONFIRM=false

# Optional private contact aliases. The list endpoint exposes alias/display/kind
# only; raw emails stay private to the deployment environment.
YAT_CONTACT_ALIASES=teammate_alpha,teammate_beta
YAT_CONTACT_TEAMMATE_ALPHA_EMAIL=teammate.alpha@example.com
YAT_CONTACT_TEAMMATE_ALPHA_DISPLAY_NAME=Teammate Alpha
YAT_CONTACT_TEAMMATE_ALPHA_KIND=colleague
YAT_CONTACT_TEAMMATE_BETA_EMAIL=teammate.beta@example.com
YAT_CONTACT_TEAMMATE_BETA_DISPLAY_NAME=Teammate Beta
YAT_CONTACT_TEAMMATE_BETA_KIND=colleague
